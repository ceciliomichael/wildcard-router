# Frontend
# Backend API base used by the Next.js route handlers and browser-side fetches.
BACKEND_API_BASE=http://localhost:3067
NEXT_PUBLIC_API_BASE=http://localhost:3067

# Optional: add tunnel hosts or local development origins here.
# Example: NEXT_ALLOWED_DEV_ORIGINS=my-tunnel.example.com,*.ngrok-free.app
NEXT_ALLOWED_DEV_ORIGINS=

# Terminal target configuration:
# - auto   : prefer docker backend service when available, fallback to host shell
# - docker : require docker backend service/container
# - host   : force local host shell
TERMINAL_TARGET=auto
TERMINAL_DOCKER_SERVICE=backend
# Optional overrides:
# TERMINAL_DOCKER_CONTAINER=
# TERMINAL_DOCKER_PROJECT=
# TERMINAL_DOCKER_COMPOSE_DIR=..
# TERMINAL_DOCKER_SHELL=/bin/sh
# TERMINAL_DOCKER_SHELL_ARGS=-l
