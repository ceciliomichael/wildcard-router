# Required: base domain used for wildcard subdomain extraction.
WILDCARD_BASE_DOMAIN=echosphere.systems

# Listen port for the Go backend.
PORT=3067

# MongoDB connection used for users, sessions, and routes.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=wildcard_catcher

# Required on first startup so the system can create the initial admin account.
# The bootstrap account now signs in with username/password like every other user.
BOOTSTRAP_ADMIN_USERNAME=main-admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
BOOTSTRAP_ADMIN_NAME=Main Admin

# Session cookie settings.
SESSION_COOKIE_NAME=wc_session
SESSION_TTL_HOURS=168

# Set true when the admin UI is served over HTTPS.
SESSION_COOKIE_SECURE=false

# Security: trust X-Forwarded-Host only when traffic always comes from a trusted proxy/tunnel.
TRUST_X_FORWARDED_HOST=true
