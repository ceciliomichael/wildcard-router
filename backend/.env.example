# Required: base domain used for subdomain extraction (e.g. test.echosphere.systems -> test)
WILDCARD_BASE_DOMAIN=echosphere.systems

# Listen port for the Go backend (Cloudflare tunnel service should point here)
PORT=3067

# Path to JSON registry file (relative to backend/ when running from backend directory)
WILDCARD_REGISTRY_PATH=data/routes.json

# Required: API key for CRUD endpoints (/api/routes). Use a long random secret.
ROUTES_API_KEY=replace-with-long-random-secret

# Security: trust X-Forwarded-Host only when traffic always comes from a trusted proxy/tunnel.
TRUST_X_FORWARDED_HOST=true
